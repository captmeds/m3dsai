# ═══════════════════════════════════════════════════════════════════════════
# m3dsEYE — AI Traffic Radar :: environment configuration
# Copy to ".env" and edit. NEVER commit your real .env file.
# ═══════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="m3dsEYE Traffic Radar"
ENVIRONMENT=development            # development | production
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── Security / Auth ──────────────────────────────────────────────────────────
# CHANGE THIS. Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-please-generate-a-real-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=480    # 8-hour shift length
ALGORITHM=HS256

# Seed admin account created by scripts/init_db.py (change before first run!)
ADMIN_EMAIL=admin@example.gov
ADMIN_PASSWORD=ChangeMe!Admin123

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, zero-config):
DATABASE_URL=sqlite:///./data/m3dseye.db
# PostgreSQL (optional — uncomment & install psycopg2-binary):
# DATABASE_URL=postgresql+psycopg2://m3dseye:password@localhost:5432/m3dseye

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_DIR=./data/storage         # cropped plates + vehicle snapshots
VIDEO_DIR=./data/videos            # uploaded / sample test videos

# ── Detection / models ───────────────────────────────────────────────────────
# When models are unavailable the system runs in MOCK mode (safe to test).
VEHICLE_MODEL_PATH=models/yolov8n.pt        # COCO model (cars/bikes/trucks/buses)
PLATE_MODEL_PATH=models/license_plate.pt    # optional dedicated plate model
DETECTION_CONFIDENCE=0.35
PLATE_CONFIDENCE=0.25
DEVICE=cpu                          # cpu | cuda | mps
FORCE_MOCK_DETECTION=false          # set true to always use the mock detector

# ── OCR ──────────────────────────────────────────────────────────────────────
OCR_ENGINE=easyocr                  # easyocr | tesseract | mock
OCR_MIN_CONFIDENCE=0.40
OCR_LANGUAGES=en

# ── Pipeline tuning ──────────────────────────────────────────────────────────
FRAME_SKIP=2                        # process every Nth frame (perf)
TRACKER_MAX_DISTANCE=80             # px; centroid match threshold
TRACKER_MAX_MISSING=30             # frames a track survives unseen
DEDUP_COOLDOWN_SECONDS=30           # don't re-log same plate within N seconds

# ── Privacy & compliance ─────────────────────────────────────────────────────
BLUR_FACES=true                     # blur detected faces in stored snapshots
BLUR_NON_PLATE=false                # blur everything except the plate region
DATA_RETENTION_DAYS=30              # auto-purge detections/images older than this
LAWFUL_USE_BANNER=true              # show authorised-use-only banner in dashboard
